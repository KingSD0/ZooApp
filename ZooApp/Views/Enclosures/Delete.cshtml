@model ZooApp.Models.Enclosure

@{
    ViewData["Title"] = "Verblijf verwijderen";
}

<h1>Verwijder verblijf</h1>

<h3>Weet je zeker dat je dit verblijf wilt verwijderen?</h3>

<div>
    <h4>Verblijf</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Name)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Climate)
        </dt>
        <dd class="col-sm-9">
            @Model.Climate
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.HabitatType)
        </dt>
        <dd class="col-sm-9">
            @Model.HabitatType
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.SecurityLevel)
        </dt>
        <dd class="col-sm-9">
            @Model.SecurityLevel
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Size)
        </dt>
        <dd class="col-sm-9">
            @(Model.Size.ToString("0.##") + " m²")
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Verwijderen</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Annuleren</a>
    </form>
</div>
