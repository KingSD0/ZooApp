@model IEnumerable<ZooApp.Models.Enclosure>

@{
    ViewData["Title"] = "Verblijven";
}

<h1 class="mb-3">Verblijfoverzicht</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Nieuw verblijf toevoegen</a>
</p>

<a asp-action="Sunrise" class="btn btn-warning mb-3">☀ Sunrise</a>
<a asp-action="Sunset" class="btn btn-info mb-3">🌇 Sunset</a>
<a asp-action="FeedingTime" class="btn btn-outline-success mb-3">🍽️ Feeding Time</a>
<a asp-action="CheckConstraints" class="btn btn-danger mb-3">🏠 Controleer verblijfseisen</a>


<table class="table table-bordered table-striped">
    <thead class="table-light">
        <tr>
            <th>@Html.DisplayNameFor(m => m.Name)</th>
            <th>@Html.DisplayNameFor(m => m.Climate)</th>
            <th>@Html.DisplayNameFor(m => m.HabitatType)</th>
            <th>@Html.DisplayNameFor(m => m.SecurityLevel)</th>
            <th>@Html.DisplayNameFor(m => m.Size)</th>
            <th>Acties</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Climate</td>
                <td>@item.HabitatType</td>
                <td>@item.SecurityLevel</td>
                <td>@item.Size</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Bewerken</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Verwijderen</a>
                </td>
            </tr>
        }
    </tbody>
</table>
