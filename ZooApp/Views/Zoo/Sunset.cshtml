@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Sunset - Dierentuin";
}

<h1>🌇 Sunset in de Dierentuin</h1>

@foreach (var enclosure in Model)
{
    var animals = enclosure.SunsetStatuses as IEnumerable<dynamic>;

    <div class="card mb-4">
        <div class="card-header bg-dark text-white fw-bold">
            Verblijf: @enclosure.EnclosureName
        </div>
        <div class="card-body">
            @if (animals == null || !animals.Any())
            {
                <p><em>Geen dieren in dit verblijf.</em></p>
            }
            else
            {
                <table class="table table-bordered table-sm">
                    <thead>
                        <tr>
                            <th>Naam</th>
                            <th>Activiteitspatroon</th>
                            <th>Status bij zonsondergang</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var animal in animals)
                        {
                            <tr>
                                <td>@animal.Name</td>
                                <td>@animal.ActivityPattern</td>
                                <td>@animal.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

<a asp-action="Index" class="btn btn-secondary mt-3">Terug naar overzicht</a>
