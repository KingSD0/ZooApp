@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Check Constraints";
}

<h1 class="mb-4">✅ Check Constraints</h1>

@foreach (var enclosure in Model)
{
    <div class="card mb-4">
        <div class="card-header bg-info text-white fw-bold">
            Verblijf: @enclosure.EnclosureName
        </div>
        <div class="card-body">
            @{
                var animals = enclosure.Constraints as IEnumerable<dynamic>; 
            }

            @if (animals != null && !animals.Any())
            {
                <p><em>Geen dieren in dit verblijf.</em></p>
            }
            else
            {
                <table class="table table-bordered table-sm">
                    <thead>
                        <tr>
                            <th>Naam</th>
                            <th>Soort</th>
                            <th>Ruimtevereiste (m²)</th>
                            <th>Beveiligingsniveau</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var animal in animals)
                        {
                            <tr class="@(animal.Status.StartsWith("✔") ? "" : "table-danger")">
                                <td>@animal.Name</td>
                                <td>@animal.Species</td>
                                <td>@animal.SpaceRequirement</td> 
                                <td>@enclosure.SecurityLevel</td> <!-- beveiliging van enclosure niet animal -->
                                <td>@animal.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}


<div class="mt-3">
    <a asp-controller="Animals" asp-action="Index" class="btn btn-outline-secondary">Terug naar overzicht</a>
</div>
