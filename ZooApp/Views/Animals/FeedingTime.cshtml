@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Feeding Time - Dieren";
}

<h1 class="mb-4">🍽️ Feeding Time per Dier</h1>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        Geen dieren gevonden.
    </div>
}
else
{
    <ul class="list-group">
        @foreach (var animal in Model)
        {
            <li class="list-group-item">
                <strong>@animal.Name</strong> (<em>@animal.DietaryClass</em>):
                @animal.Description
            </li>
        }
    </ul>
}

<p class="mt-3">
    <a asp-controller="Animals" asp-action="Index" class="btn btn-outline-secondary">Terug naar overzicht</a>
</p>
