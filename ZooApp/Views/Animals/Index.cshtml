@model IEnumerable<ZooApp.Models.Animal>

@{
    ViewData["Title"] = "Dierenoverzicht";

    var currentFilters = ViewBag.CurrentFilters;
    string name = currentFilters?.name ?? "";
    string species = currentFilters?.species ?? "";
    int? categoryId = currentFilters?.categoryId;
    var sizes = (SelectList)ViewBag.Size;
    var diets = (SelectList)ViewBag.DietaryClass;
    var activities = (SelectList)ViewBag.ActivityPattern;
    var security = (SelectList)ViewBag.SecurityRequirement;
    var categories = (SelectList)ViewData["CategoryId"];
}

<h1 class="mb-4">Dierenoverzicht</h1>

<p>
    <a asp-action="Create" class="btn btn-success mb-3">Nieuw dier toevoegen</a>
</p>
<a asp-action="Sunrise" class="btn btn-warning mb-3">☀ Sunrise</a>
<a asp-action="Sunset" asp-controller="Animals" class="btn btn-info mb-3">🌇 Sunset</a>
<a asp-action="FeedingTime" class="btn btn-outline-success mb-3">🍽️ Feeding Time</a>

<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-2">
            <label for="name" class="form-label">Naam</label>
            <input type="text" name="name" value="@Context.Request.Query["name"]" class="form-control" placeholder="Zoek op naam" />
        </div>
        <div class="col-md-2">
            <label for="species" class="form-label">Soort</label>
            <input type="text" name="species" value="@Context.Request.Query["species"]" class="form-control" placeholder="Zoek op soort" />
        </div>
        <div class="col-md-2">
            <label for="categoryId" class="form-label">Categorie</label>
            @Html.DropDownList("categoryId", (SelectList)ViewData["CategoryId"], "Categorie", new { @class = "form-select", onchange = "this.form.submit()" })
        </div>
        <div class="col-md-2">
            <label for="size" class="form-label">Grootte</label>
            @Html.DropDownList("size", (SelectList)ViewData["Size"], "Grootte", new { @class = "form-select", onchange = "this.form.submit()" })
        </div>
        <div class="col-md-2">
            <label for="dietaryClass" class="form-label">Voeding</label>
            @Html.DropDownList("dietaryClass", (SelectList)ViewData["DietaryClass"], "Voedingsklasse", new { @class = "form-select", onchange = "this.form.submit()" })
        </div>
        <div class="col-md-2">
            <label for="activityPattern" class="form-label">Activiteit</label>
            @Html.DropDownList("activityPattern", (SelectList)ViewData["ActivityPattern"], "Activiteit", new { @class = "form-select", onchange = "this.form.submit()" })
        </div>

        <div class="col-md-2">
            <label for="securityRequirement" class="form-label">Beveiliging</label>
            @Html.DropDownList("securityRequirement", (SelectList)ViewData["SecurityRequirement"], "Beveiliging", new { @class = "form-select", onchange = "this.form.submit()" })
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Zoeken</button>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <a asp-action="Index" class="btn btn-secondary w-100">Reset</a>
        </div>
    </div>
</form>


<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Naam</th>
                <th>Soort</th>
                <th>Categorie</th>
                <th>Grootte</th>
                <th>Voedingsklasse</th>
                <th>Activiteitspatroon</th>
                <th>Verblijf</th>
                <th>Ruimte (m²)</th>
                <th>Beveiliging</th>
                <th>Acties</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Species</td>
                    <td>@(item.Category?.Name ?? "Geen")</td>
                    <td>@item.Size</td>
                    <td>@item.DietaryClass</td>
                    <td>@item.ActivityPattern</td>
                    <td>@(item.Enclosure?.Name ?? "Geen")</td>
                    <td>@item.SpaceRequirement.ToString("0.##")</td>
                    <td>@item.SecurityRequirement</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary me-1 mb-1">Wijzig</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1 mb-1">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger mb-1">Verwijder</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
