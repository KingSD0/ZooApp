@model ZooApp.Models.Category

@{
    ViewData["Title"] = "Categoriegegevens";
}

<h1>Categoriegegevens</h1>

<div>
    <h4>Details van de categorie</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Name)
        </dd>
    </dl>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Bewerken</a>
    <a asp-action="Index" class="btn btn-secondary">Terug naar overzicht</a>
</div>
