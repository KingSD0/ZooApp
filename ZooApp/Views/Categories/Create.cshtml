@model ZooApp.Models.Category

@{
    ViewData["Title"] = "Categorie toevoegen";
}

<h1>Categorie toevoegen</h1>

<h4>Nieuwe categorie</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Bijv. Zoogdieren" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Opslaan" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Annuleren</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
