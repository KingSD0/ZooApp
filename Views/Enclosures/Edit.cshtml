@model ZooApp.Models.Enclosure

@using ZooApp.Models
@{
    ViewData["Title"] = "Edit";
    var climateOptions = Enum.GetValues(typeof(Climate)).Cast<Climate>();
    var securityOptions = Enum.GetValues(typeof(SecurityLevel)).Cast<SecurityLevel>();
    var habitatOptions = Enum.GetValues(typeof(HabitatType))
                             .Cast<HabitatType>()
                             .Where(h => h != HabitatType.None);
}

<h1>Edit</h1>

<h4>Enclosure</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Climate" class="control-label"></label>
                <select asp-for="Climate" class="form-control">
                    @foreach (var option in climateOptions)
                    {
                        <option value="@option" selected="@(Model.Climate == option)">
                            @option
                        </option>
                    }
                </select>
                <span asp-validation-for="Climate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">HabitatType</label>
                <div class="form-check">
                    @foreach (var option in habitatOptions)
                    {
                        <div>
                            <input type="checkbox"
                                   name="habitatValues"
                                   value="@((int)option)"
                                   class="form-check-input"
                            @(Model.HabitatType.HasFlag(option) ? "checked" : "") />
                            <label class="form-check-label">@option</label>
                        </div>
                    }
                </div>
                <span asp-validation-for="HabitatType" class="text-danger"></span>
            </div>


            <div class="form-group">
                <label asp-for="SecurityLevel" class="control-label"></label>
                <select asp-for="SecurityLevel" class="form-control">
                    @foreach (var option in securityOptions)
                    {
                        <option value="@option" selected="@(Model.SecurityLevel == option)">
                            @option
                        </option>
                    }
                </select>
                <span asp-validation-for="SecurityLevel" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Size" class="control-label"></label>
                <input asp-for="Size" class="form-control" />
                <span asp-validation-for="Size" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Annuleren</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
