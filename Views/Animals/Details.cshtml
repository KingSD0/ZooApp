@model ZooApp.Models.Animal

@{
    ViewData["Title"] = "Dierdetails";
}

<h1>Dierdetails</h1>

<div class="mt-3">
    <h4>Dierinformatie</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Naam</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Soort</dt>
        <dd class="col-sm-9">@Model.Species</dd>

        <dt class="col-sm-3">Categorie</dt>
        <dd class="col-sm-9">
            @(Model.Category != null ? Model.Category.Name : "Geen")
        </dd>

        <dt class="col-sm-3">Grootte</dt>
        <dd class="col-sm-9">@Model.Size</dd>

        <dt class="col-sm-3">Voedingsklasse</dt>
        <dd class="col-sm-9">@Model.DietaryClass</dd>

        <dt class="col-sm-3">Activiteitspatroon</dt>
        <dd class="col-sm-9">@Model.ActivityPattern</dd>

        <dt class="col-sm-3">Verblijf</dt>
        <dd class="col-sm-9">
            @(Model.Enclosure != null ? Model.Enclosure.Name : "Geen")
        </dd>

        <dt class="col-sm-3">Ruimtevereiste (m²)</dt>
        <dd class="col-sm-9">@Model.SpaceRequirement</dd>

        <dt class="col-sm-3">Beveiligingsniveau</dt>
        <dd class="col-sm-9">@Model.SecurityRequirement</dd>
    </dl>
</div>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Wijzig</a>
    <a asp-action="Index" class="btn btn-secondary">Terug naar overzicht</a>
</div>
